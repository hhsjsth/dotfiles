[Unit]
Description=Mount Rclone Drive
After=network-online.target

[Service]
Type=notify
ExecStart=/usr/bin/rclone mount alist-host: /home/gtr/share/gtr-host --config /home/gtr/.config/rclone/rclone.conf --allow-other --uid=1000 --gid=1000 --vfs-cache-mode full --cache-dir /mnt/rclone_cache --vfs-cache-max-size 4G
ExecStop=/usr/bin/fusermount3 -u /home/gtr/share/gtr-host
Restart=on-failure

[Install]
WantedBy=multi-user.target

